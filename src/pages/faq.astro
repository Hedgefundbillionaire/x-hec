---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site";

const title = "FAQ Admission Grandes Écoles | Dream School";
const description = "Réponses aux questions fréquentes sur Dream School, X-HEC Entrepreneurs, coaching admission et préparation entretien.";
const faqs = [
  ["Dream School est-il affilié à HEC Paris ?", "Non. Dream School est un service de coaching indépendant, non affilié à HEC Paris, l'École Polytechnique ou une autre école."],
  ["Le calculateur garantit-il une admission ?", "Non. Il donne une estimation indicative et des axes de travail. Seul le jury officiel décide."],
  ["Travaillez-vous seulement X-HEC Entrepreneurs ?", "Le premier guide cible X-HEC Entrepreneurs. L'architecture est prévue pour HEC MIM, ESSEC GE, ESCP et INSEAD."],
  ["La préparation peut-elle se faire en anglais ?", "Oui, mais le contenu principal du site est français pour couvrir les requêtes longues françaises."],
  ["Comment fonctionne l'appel gratuit ?", "L'appel de 20 minutes sert à évaluer l'adéquation profil-programme et à identifier les priorités du dossier."]
];
const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([name, text]) => ({ "@type": "Question", name, acceptedAnswer: { "@type": "Answer", text } }))
}, {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: site.url },
    { "@type": "ListItem", position: 2, name: "FAQ", item: `${site.url}/faq` }
  ]
}];
---

<BaseLayout title={title} description={description} path="/faq" jsonLd={jsonLd}>
  <main class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">FAQ admission Grandes Écoles</h1>
    <div class="mt-10 grid gap-5">
      {faqs.map(([question, answer]) => (
        <section class="border border-navy/10 bg-white p-6 shadow-soft">
          <h2 class="font-serif text-2xl font-semibold text-navy">{question}</h2>
          <p class="mt-3 leading-7 text-ink/72">{answer}</p>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
