---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Contact Dream School | Coaching Admission";
const description = "Contactez Dream School pour une préparation X-HEC Entrepreneurs, HEC, ESSEC, ESCP ou INSEAD.";
---
<BaseLayout title={title} description={description} path="/contact">
  <main class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">Contact</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">Écrivez à contact@dreamschool.com ou réservez directement un diagnostic gratuit de 20 minutes.</p>
    <a class="mt-8 inline-block bg-navy px-6 py-4 text-sm font-bold text-white" href="/reservation">Réserver un appel</a>
  </main>
</BaseLayout>
