---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "À propos de Dream School | Coaching Admission";
const description = "Dream School accompagne les candidats aux programmes sélectifs avec une méthode professionnelle et data-driven.";
---
<BaseLayout title={title} description={description} path="/a-propos">
  <main class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">À propos</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">Dream School construit des ressources et accompagnements premium pour les admissions Grandes Écoles. Le site est indépendant et pensé pour publier des guides profonds par programme.</p>
  </main>
</BaseLayout>
