---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Blog Admission Grandes Écoles | Dream School";
const description = "Analyses et guides SEO sur X-HEC Entrepreneurs, HEC, ESSEC, ESCP, INSEAD et les candidatures sélectives.";
---
<BaseLayout title={title} description={description} path="/blog">
  <main class="mx-auto max-w-5xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">Blog admission Grandes Écoles</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">Espace prêt pour les articles MDX: comparatifs, calendriers, entretiens, coûts, retours d'expérience et stratégies de candidature.</p>
  </main>
</BaseLayout>
