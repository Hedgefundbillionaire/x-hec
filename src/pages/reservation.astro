---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Réserver un appel gratuit | Dream School";
const description = "Réservez un diagnostic gratuit de 20 minutes pour votre candidature X-HEC Entrepreneurs ou Grandes Écoles.";
---
<BaseLayout title={title} description={description} path="/reservation" noSticky>
  <main class="mx-auto max-w-5xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">Réserver un appel gratuit</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">Remplacez ce bloc par votre embed Calendly lorsque le lien sera prêt.</p>
    <div class="mt-8 flex min-h-[520px] items-center justify-center border border-navy/10 bg-mist text-navy/65">Calendly embed placeholder</div>
  </main>
</BaseLayout>
