---
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "X-HEC Entrepreneurs Admissions Guide 2026";
const description = "English mirror for the X-HEC Entrepreneurs admissions guide: application, interview, funding and outcomes.";
---
<BaseLayout title={title} description={description} path="/en/x-hec-entrepreneurs" lang="en" type="article">
  <main class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">X-HEC Entrepreneurs admissions guide.</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">English placeholder. The full French guide is the primary SEO page and can be mirrored here section by section.</p>
    <a class="mt-8 inline-block bg-navy px-6 py-4 text-sm font-bold text-white" href="/x-hec-entrepreneurs">French guide</a>
  </main>
</BaseLayout>
