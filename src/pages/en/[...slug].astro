---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pages = {
  "about": ["About Dream School | Admissions Coaching", "Learn about Dream School, an independent admissions coaching service.", "About Dream School"],
  "faq": ["Admissions FAQ | Dream School", "Frequently asked questions about Dream School and selective school admissions.", "Admissions FAQ"],
  "contact": ["Contact Dream School | Admissions Coaching", "Contact Dream School for X-HEC Entrepreneurs and Grande École admissions coaching.", "Contact"],
  "blog": ["Admissions Blog | Dream School", "Insights on X-HEC Entrepreneurs, HEC, ESSEC, ESCP, INSEAD and selective applications.", "Admissions Blog"],
  "legal-notice": ["Legal Notice | Dream School", "Legal notice for Dream School.", "Legal Notice"],
  "privacy-policy": ["Privacy Policy | Dream School", "Privacy policy for Dream School email collection, Brevo and analytics.", "Privacy Policy"],
  "admissions-calculator": ["Admissions Calculator | Dream School", "Estimate your X-HEC Entrepreneurs admissions chances.", "Admissions Calculator"],
  "thank-you": ["Thank You | Dream School", "Your Dream School request has been received.", "Thank you"],
  "booking": ["Book a Free Call | Dream School", "Book a free 20-minute admissions diagnostic.", "Book a Free Call"]
};

export function getStaticPaths() {
  return Object.entries(pages).map(([slug, data]) => ({ params: { slug }, props: { data } }));
}

const slug = Astro.params.slug as keyof typeof pages;
const [title, description, h1] = Astro.props.data;
---

<BaseLayout title={title} description={description} path={`/en/${slug}`} lang="en" noSticky={slug === "legal-notice" || slug === "privacy-policy"}>
  <main class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">{h1}</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">English mirror placeholder. The French version is primary; this page is wired for international SEO and can be expanded when English copy is ready.</p>
    <a class="mt-8 inline-block bg-navy px-6 py-4 text-sm font-bold text-white" href="/">French homepage</a>
  </main>
</BaseLayout>
