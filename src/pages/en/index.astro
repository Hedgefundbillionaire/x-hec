---
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "Dream School: Grande École Admissions Coaching";
const description = "Premium admissions coaching for X-HEC Entrepreneurs, HEC, ESSEC, ESCP and INSEAD.";
---
<BaseLayout title={title} description={description} path="/en/" lang="en">
  <main class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">Grande École admissions coaching.</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">English mirror placeholder. The French site is the primary SEO version; English pages are wired for hreflang from day one.</p>
    <a class="mt-8 inline-block bg-navy px-6 py-4 text-sm font-bold text-white" href="/x-hec-entrepreneurs">Read the French X-HEC guide</a>
  </main>
</BaseLayout>
