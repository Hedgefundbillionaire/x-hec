---
import BaseLayout from "../layouts/BaseLayout.astro";
import InlineCTA from "../components/InlineCTA.astro";
import { site } from "../site";

const title = "Dream School : Coaching Admission Grandes Écoles | X-HEC, HEC, ESSEC";
const description = "Coaching premium en français pour réussir X-HEC Entrepreneurs, HEC, ESSEC, ESCP et INSEAD avec une stratégie d'admission claire.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    url: site.url,
    logo: `${site.url}/images/dream-school-og.svg`,
    sameAs: []
  }
];
---

<BaseLayout title={title} description={description} path="/" jsonLd={jsonLd}>
  <main>
    <section class="bg-mist">
      <div class="mx-auto grid max-w-7xl gap-12 px-5 py-16 lg:grid-cols-[1.05fr_.95fr] lg:items-center lg:py-24">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-gold">Coaching admissions Grandes Écoles</p>
          <h1 class="mt-5 max-w-4xl font-serif text-5xl font-bold leading-[1.02] text-navy md:text-7xl">Entrer dans l'école qui change la trajectoire.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/72">Dream School accompagne les candidats ambitieux vers les programmes les plus sélectifs: X-HEC Entrepreneurs, HEC Grande École, ESSEC, ESCP et INSEAD. Méthode française, positionnement premium, préparation documentée.</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="bg-navy px-6 py-4 text-center text-sm font-bold text-white hover:bg-navy/90" href="/x-hec-entrepreneurs">Lire le guide X-HEC</a>
            <a class="border border-navy/20 px-6 py-4 text-center text-sm font-bold text-navy hover:border-gold" href="/calculateur-admission">Calculer mes chances</a>
          </div>
          <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-4 border-t border-navy/10 pt-6">
            <div><dt class="text-2xl font-bold text-navy">2026</dt><dd class="mt-1 text-sm text-ink/65">Admissions ciblées</dd></div>
            <div><dt class="text-2xl font-bold text-navy">FR</dt><dd class="mt-1 text-sm text-ink/65">Contenu natif français</dd></div>
            <div><dt class="text-2xl font-bold text-navy">20 min</dt><dd class="mt-1 text-sm text-ink/65">Diagnostic offert</dd></div>
          </dl>
        </div>
        <figure>
          <img class="aspect-[16/10] w-full object-cover shadow-soft" src="/images/dream-school-og.svg" alt="Illustration premium du parcours d'admission X-HEC Entrepreneurs" width="1600" height="1000" loading="eager" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-5 py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-gold">Premier guide</p>
        <h2 class="mt-4 font-serif text-4xl font-bold leading-tight text-navy md:text-5xl">X-HEC Entrepreneurs, sans folklore.</h2>
        <p class="mt-5 text-lg leading-8 text-ink/72">Le marché existe déjà, mais il est surtout anglophone, informel et centré sur l'expérience d'un alumni. Dream School construit une ressource longue, vérifiable et orientée conversion pour les requêtes françaises: admission X-HEC Entrepreneurs, entretien X-HEC, candidature, coût, débouchés et avis.</p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {[
          ["Diagnostic", "Un score d'admission indicatif et trois points faibles personnalisés."],
          ["Dossier", "CV, lettre, recommandations et récit entrepreneurial alignés."],
          ["Entretien", "Questions probables, simulations, structure de pitch et objections."]
        ].map(([heading, copy]) => (
          <article class="border border-navy/10 bg-white p-6 shadow-soft">
            <h3 class="font-serif text-2xl font-semibold text-navy">{heading}</h3>
            <p class="mt-3 leading-7 text-ink/70">{copy}</p>
          </article>
        ))}
      </div>
      <InlineCTA title="Commencez par un diagnostic objectif" copy="Le calculateur donne une première lecture de votre profil avant de travailler le récit, les preuves et l'entretien." />
    </section>
  </main>
</BaseLayout>
