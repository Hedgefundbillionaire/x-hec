---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Mentions légales | Dream School";
const description = "Mentions légales de Dream School: éditeur, hébergeur, responsabilité et contact.";
---
<BaseLayout title={title} description={description} path="/mentions-legales" noSticky>
  <main class="content mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-serif text-5xl font-bold text-navy">Mentions légales</h1>
    <p><strong>Éditeur:</strong> Dream School, SIRET à compléter, adresse à compléter.</p>
    <p><strong>Directeur de la publication:</strong> nom à compléter.</p>
    <p><strong>Hébergement:</strong> Vercel Inc., 340 S Lemon Ave #4133, Walnut, CA 91789, États-Unis.</p>
    <p>Dream School est un service indépendant, non affilié à HEC Paris ni à l'École Polytechnique.</p>
  </main>
</BaseLayout>
