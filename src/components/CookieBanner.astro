<div id="cookie-banner" class="fixed bottom-24 left-4 z-50 hidden max-w-md border border-navy/10 bg-white p-4 shadow-soft">
  <p class="text-sm leading-6 text-ink/75">Nous utilisons uniquement des cookies essentiels. Les mesures d'audience Plausible sont anonymes et sans cookie.</p>
  <div class="mt-3 flex items-center justify-end gap-2">
    <button class="border border-navy/20 px-3 py-2 text-sm font-semibold text-navy" data-cookie-close>Fermer</button>
    <button class="bg-navy px-3 py-2 text-sm font-semibold text-white" data-cookie-accept>Compris</button>
  </div>
</div>

<script>
  const banner = document.querySelector("#cookie-banner");
  const accepted = localStorage.getItem("dreamschool_cookie_notice");
  if (!accepted) banner?.classList.remove("hidden");
  document.querySelectorAll("[data-cookie-close], [data-cookie-accept]").forEach((button) => {
    button.addEventListener("click", () => {
      localStorage.setItem("dreamschool_cookie_notice", "ok");
      banner?.classList.add("hidden");
    });
  });
</script>
