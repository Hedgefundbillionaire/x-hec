---
const title = Astro.props.title ?? "Préparez votre candidature avec méthode";
const copy = Astro.props.copy ?? "Recevez le guide gratuit X-HEC Entrepreneurs: calendrier, pièces du dossier, grille d'entretien et erreurs à éviter.";
---

<aside class="cta-card">
  <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <p class="font-serif text-2xl font-semibold text-navy">{title}</p>
      <p class="mt-2 text-base leading-7 text-ink/75">{copy}</p>
    </div>
    <a class="bg-navy px-5 py-3 text-center text-sm font-bold text-white hover:bg-navy/90" href="/calculateur-admission">Tester mes chances</a>
  </div>
</aside>
