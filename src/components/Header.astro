---
import Logo from "./Logo.astro";
import { navFr } from "../site";
---

<header class="sticky top-0 z-40 border-b border-navy/10 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
    <Logo />
    <nav class="hidden items-center gap-7 text-sm font-medium text-navy/80 lg:flex" aria-label="Navigation principale">
      {navFr.map((item) => <a class="hover:text-navy" href={item.href}>{item.label}</a>)}
    </nav>
    <div class="flex items-center gap-3">
      <a class="hidden text-sm font-medium text-navy/70 hover:text-navy sm:inline" href="/en/">EN</a>
      <a class="bg-navy px-4 py-2 text-sm font-semibold text-white shadow-soft hover:bg-navy/90" href="/reservation">Appel gratuit</a>
    </div>
  </div>
</header>
